# WinForge .gitignore

# Logs
*.log
WinForge_*.log

# Registry backup files (user-specific, generated on install)
WinForge_Backups/
*.reg.backup

# PowerToys backup (user-specific settings)
configs/powertoys/*.ptb

# VS Code local workspace
.vscode/

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test output
tests/results/
*.xml
