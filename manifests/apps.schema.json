{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WinForge Apps Manifest",
  "type": "object",
  "required": ["version", "tiers"],
  "properties": {
    "version":     { "type": "string" },
    "description": { "type": "string" },
    "notes":       { "type": "array", "items": { "type": "string" } },
    "scoopBuckets":{ "type": "array", "items": { "type": "string" } },
    "tiers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "packages"],
        "properties": {
          "label":   { "type": "string" },
          "extends": { "type": "string" },
          "packages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "source"],
              "properties": {
                "id":       { "type": "string" },
                "source":   { "enum": ["winget", "scoop", "store", "manual", "script"] },
                "bucket":   { "type": "string" },
                "script":   { "type": "string", "description": "Optional path (relative to repo root) to a PowerShell script to run for source='script' entries." },
                "notes":    { "type": "string" },
                "optional": { "type": "boolean" },
                "manual":   { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "vscodeExtensions": { "type": "array", "items": { "type": "string" } },
    "wslDistros":       { "type": "array" }
  }
}
