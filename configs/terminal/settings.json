  "schemes": [
    {
      "name": "WinForge Dark",
      "background": "#171614",
      "foreground": "#cdccca",
      "black": "#171614",
      "red": "#d163a7",
      "green": "#6daa45",
      "yellow": "#e8af34",
      "blue": "#4f98a3",
      "purple": "#a86fdf",
      "cyan": "#4f98a3",
      "white": "#cdccca",
      "brightBlack": "#5a5957",
      "brightRed": "#dd6974",
      "brightGreen": "#6daa45",
      "brightYellow": "#fdab43",
      "brightBlue": "#5591c7",
      "brightPurple": "#a86fdf",
      "brightCyan": "#4f98a3",
      "brightWhite": "#f7f6f2",
      "cursorColor": "#4f98a3",
      "selectionBackground": "#4f98a340"
    }
  ],
  "keybindings": [
    { "command": { "action": "splitPane", "split": "auto" }, "keys": "alt+shift+d" },
    { "command": "closePane", "keys": "alt+shift+w" },
    { "command": { "action": "newTab" }, "keys": "ctrl+t" },
    { "command": "closeTab", "keys": "ctrl+w" },
    { "command": { "action": "copy", "singleLine": false }, "keys": "ctrl+c" },
    { "command": "paste", "keys": "ctrl+v" },
    { "command": "find", "keys": "ctrl+shift+f" }
